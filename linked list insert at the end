class Node:
    def __init__(self,data):
        self.data=data
        self.next=None
class Solution:
    def insert(self,head,x):
        new_node=Node(x)
        current=head
        while(current.next!=None):
            current=current.next
        current.next=new_node
        return head
    def printlist(self,head):
        while head:
            print(head.data,end=" ")
            head=head.next
head=Node(10)
head.next=Node(20)
head.next.next=Node(30)

n=int(input("Enter the number"))
obj=Solution()
obj.insert(head,n)
obj.printlist(head)
