class Node:
    def __init__(self,data):
        self.data=data
        self.next=None
class Solution:
    
    def insert(self,head,pos,x):
        new_node=Node(x)
        if pos==0:
            new_node.next=head
            return new_node
        else:
            count=1
            current=head
            while(pos!=count):
                current=current.next
                count=count+1
            new_node.next=current.next
            current.next=new_node
            return head
    def printlist(self,head):
        while head:
            print(head.data,end=" ")
            head=head.next
